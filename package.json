{
    "name": "trade-data-analyzer",
    "version": "1.0.0",
    "description": "AI-powered trade data analyzer with material-specific classification",
    "main": "electron/main.js",
    "scripts": {
        "start": "concurrently \"npm run start:backend\" \"npm run start:electron\"",
        "start:backend": "venv\\Scripts\\python.exe backend/flask_app.py",
        "start:electron": "wait-on http://127.0.0.1:5000 && electron .",
        "build": "electron-builder",
        "dev": "electron ."
    },
    "keywords": [
        "electron",
        "trade-data",
        "ai",
        "gemini"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1",
        "concurrently": "^8.2.2",
        "wait-on": "^7.2.0"
    },
    "dependencies": {
        "axios": "^1.6.0"
    },
    "build": {
        "appId": "com.trade-data-analyzer",
        "productName": "Trade Data AI Analyzer",
        "directories": {
            "output": "dist"
        },
        "files": [
            "electron/**/*",
            "frontend/**/*",
            "backend/**/*",
            "config/**/*",
            "core/**/*",
            ".env"
        ],
        "win": {
            "target": "nsis",
            "icon": "assets/icon.ico"
        }
    }
}